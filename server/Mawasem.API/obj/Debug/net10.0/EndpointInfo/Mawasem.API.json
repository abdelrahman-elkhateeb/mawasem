        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Seasons"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Seasons/active": {
      "get": {
        "tags": [
          "Seasons"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
